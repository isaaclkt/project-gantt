# ==================================================
# ProjectFlow Gantt - Backend Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ==================================================

# -------------------------
# Flask
# -------------------------
FLASK_ENV=development        # development | testing | production
PORT=5000                    # Port the backend listens on (run.py)

# -------------------------
# Security keys
# -------------------------
# In development these may be left as-is (a random key is generated per run,
# with a warning). In production they are REQUIRED and must be strong random
# values, otherwise the app refuses to start. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-in-production

# -------------------------
# Database  (THIS is what the app actually reads)
# -------------------------
# The application uses SQLAlchemy and reads a single DATABASE_URL.
# MySQL (recommended / the project default):
DATABASE_URL=mysql+pymysql://root:your_mysql_password@localhost:3306/project_grantt
#
# Quick start WITHOUT MySQL (SQLite file) — handy for local dev, but note the
# seed script (scripts/seed_database.py) is MySQL-only:
#   DATABASE_URL=sqlite:///dev.db

# -------------------------
# CORS  (comma-separated list of allowed frontend origins)
# -------------------------
# Next.js dev server may fall back to 3001-3003 if 3000 is taken.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# -------------------------
# Redis  (optional; recommended in production for token blacklist + rate limit)
# -------------------------
# If unset, an in-memory fallback is used (fine for single-instance dev).
# REDIS_URL=redis://localhost:6379/0
